# Google Docs — ID документа с товарным контентом
PRODUCT_DOC_ID=your_google_doc_id_here

# Путь к JSON-ключу сервисного аккаунта Google
# Аккаунт должен иметь роль Viewer на документе
GOOGLE_SERVICE_ACCOUNT_JSON=/Users/yourname/.config/gcloud/service_account.json

# Anthropic API (для pipeline/build_modules.py)
ANTHROPIC_API_KEY=sk-ant-api03-...
